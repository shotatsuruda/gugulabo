# ============================================================
# .env.example - 環境変数の設定サンプル
# このファイルをコピーして .env という名前で保存し、各値を設定してください。
# ============================================================

# ===== Flask設定 =====
# セッション暗号化に使用するランダムな文字列（必ず変更してください）
FLASK_SECRET_KEY=your-very-secret-random-key-here

# ===== 店舗情報 =====
# お店の名前（AI返答文の署名に使用されます）
SHOP_NAME=あなたのマッサージ店名

# ===== メール送信設定（クーポン自動送信に必要） =====
# Gmailの場合: パスワードは「アプリパスワード」を使用してください
# アプリパスワードの発行: https://myaccount.google.com/apppasswords
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your@gmail.com

# ===== OpenRouter API設定（AI返答生成に必要） =====
# https://openrouter.ai/keys で取得できます
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# ===== 本番環境向け設定 (Production) =====
# 開発環境の場合は development、本番環境の場合は production を指定
FLASK_ENV=development

# データベース設定 (SQLiteではなくPostgreSQLなどを使用する場合)
# 例: postgresql://user:password@localhost/dbname
# DATABASE_URL=

# ===== 週次LINE通知設定 =====
# Google Places API キー（口コミ取得に必要）
PLACES_API_KEY=your_google_places_api_key

# LINE Messaging API 設定
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_ADD_FRIEND_URL=https://lin.ee/xxxxxxx

# ===== Stripe 決済設定 =====
# 本番環境時は Live API Key を、開発時は Test API Key を指定
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_monthly_test...
# STRIPE_PRICE_ID_YEARLY=price_yearly_test...
# STRIPE_WEBHOOK_SECRET=whsec_...

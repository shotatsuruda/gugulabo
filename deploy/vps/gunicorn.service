[Unit]
Description=Gugulabo Flask App
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/massage-review-system
EnvironmentFile=/etc/gugulabo.env
ExecStart=/home/ubuntu/massage-review-system/.venv/bin/gunicorn -w 3 -k gthread -t 60 -b 127.0.0.1:8000 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

